# Copy this file to .env.local and fill in your own values.
# .env.local is gitignored by default in Vite projects.

# URL of a webhook (Zapier, Make, n8n, or your own endpoint) that receives
# contact form submissions as a POST with a JSON body. If left unset, the
# Contact page form will show a "not connected yet" message instead of
# silently failing.
VITE_CONTACT_WEBHOOK_URL=
